## Request Language Pages

request-language-heading = Funsani za chilankhulo chatsopano
request-language-form-email =
    .label = Adilesi yanu ya imelo
request-language-form-info =
    .label = Zambiri zokhudza chilankhulocho
request-language-form-info-explanation = Onjezani zambiri momwe mungathere zokhudza chilankhulocho. Izi zitha kuphatikizapo:
request-language-form-info-explanation-list-1 = Mayina a chilankhulo chanu
request-language-form-info-explanation-list-2 = <isoCodeLink>Makodi a ISO</isoCodeLink> ngati akudziwika
request-language-form-info-explanation-list-3 = Maulalo a mawebusayiti omwe angatithandize kumvetsetsa chilankhulocho
request-language-google-recaptcha-required = reCAPTCHA ikufunika ngati mukufuna kupitiliza
request-language-google-recaptcha-error = Chinachake chalakwika ndi reCAPTCHA. Yesaninso.
# Success page
request-language-success-heading = Zikomo! Mwatumiza funso latsopano lokhudza chinenero
request-language-success-list-1 = Muyenera kulandira imelo kuchokera kwa Woyang'anira Gulu Lathu yofotokoza njira zowonjezerera chilankhulo chanu ku Common Voice
request-language-success-list-2 = Woyang'anira dera lathu adzalumikizana nanu kuti akupatseni chithandizo chowonjezera, ndikukudziwitsani ngati pali kale gulu lomwe likugwira ntchito pa chilankhulo chanu.
request-language-success-list-3 =
    Ngati simunamve kuchokera kwa ife patatha masiku angapo,
    titumizireni uthenga pa <emailLink>{ $email }</emailLink>
    ndipo tidzakuyankhani!
request-language-error =
    Mwina sitinalandire pempho limenelo. Chonde titumizireni imelo mwachindunji
    pa <emailLink>{ $email }</emailLink> ndipo tidzakuyankhani!
