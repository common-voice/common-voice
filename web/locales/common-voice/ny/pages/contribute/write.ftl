## SMALL BATCH SUBMISSION

# <icon></icon> will be replaced with an icon that represents writing a sentence
small-batch-instruction = <icon></icon> Onjezani ziganizo zingapo za anthu onse
multiple-sentences-error = Simungathe kuwonjezera ziganizo zingapo pa uthenga umodzi
exceeds-small-batch-limit-error = Simungathe kupereka ziganizo zoposa 1000
# $retryLimit represents the amount of time in minutes a user has to wait to retry an upload
rate-limit-toast-message-minutes =
    { $retryLimit ->
        [one] Malire a mlingo adutsa. Yesaninso mu mphindi { $retryLimit }
       *[other] { "" }
    }
# $retryLimit represents the amount of time in seconds a user has to wait to retry an upload
rate-limit-toast-message-seconds =
    { $retryLimit ->
        [one] Malire a mlingo adutsa. Yesaninso mu masekondi { $retryLimit }
       *[other] { "" }
    }
# $retryLimit represents the amount of time in minutes a user has to wait to retry an upload
rate-limit-message-minutes =
    { $retryLimit ->
        [one] Mwafika pa malire otumizira tsamba lino. Chonde dikirani kwa mphindi { $retryLimit } musanatumize chiganizo china. Zikomo chifukwa cha kuleza mtima kwanu!
       *[other] { "" }
    }
# $retryLimit represents the amount of time in seconds a user has to wait to retry an upload
rate-limit-message-seconds =
    { $retryLimit ->
        [one] Mwafika pa malire otumizira tsamba lino. Chonde dikirani kwa masekondi { $retryLimit } musanatumize chiganizo china. Zikomo chifukwa cha kuleza mtima kwanu!
       *[other] { "" }
    }
# $uploadedSentences represents the number of sentences accepted from the small batch submission, $totalSentences represents the total number of sentences in the small batch submission
add-small-batch-success =
    { $totalSentences ->
        [one] Ziganizo { $uploadedSentences } za { $totalSentences } zomwe zasonkhanitsidwa
       *[other] { "" }
    }
# $uploadedSentences represents the number of sentences accepted from the small batch submission, $totalSentences represents the total number of sentences in the small batch submission
small-batch-response-message =
    { $totalSentences ->
        [one] { $uploadedSentences } ya ziganizo { $totalSentences } zomwe zasonkhanitsidwa. Dinani <downloadLink>pano</downloadLink> kuti mutsitse ziganizo zokanidwa.
       *[other] { "" }
    }
small-batch-sentences-rule-1 = Tsatirani malangizo ochokera mu “Ndi ziganizo ziti zomwe ndingawonjezere?”
small-batch-sentences-rule-2 = Onjezani chiganizo chimodzi pamzere uliwonse
small-batch-sentences-rule-3 = Gawani ziganizo mu mzere umodzi podina "Enter" kapena "Return" kamodzi
small-batch-sentences-rule-4 = Onjezani ziganizo zokwana 1,000
small-batch-sentences-rule-5 = Chiganizo chonse chiyenera kukhala ndi dzina lofanana
small-batch-sentences-rule-6 = Ziganizo zonse ziyenera kukhala ndi mawu ofanana
# menu item
add-sentences = Wonjezelani ziganizo

