# $retryLimit represents the amount of time in minutes a user has to wait to retry an upload
rate-limit-toast-message-minutes =
    { $retryLimit ->
        [one] Прекорачено је ограничење брзине. Покушајте поново за 1 минут
        [few] Прекорачено је ограничење брзине. Покушајте поново за { $count } минута
       *[other] Прекорачено је ограничење брзине. Покушајте поново за { $count } минута
    }
# $retryLimit represents the amount of time in seconds a user has to wait to retry an upload
rate-limit-toast-message-seconds =
    { $retryLimit ->
        [one] Ограничење учесталости је прекорачено. Покушајте поново за 1 секунду
        [few] Ограничење учесталости је прекорачено. Покушајте поново за { $retryLimit } секунде
       *[other] Ограничење учесталости је прекорачено. Покушајте поново за { $retryLimit } секунди
    }
# $retryLimit represents the amount of time in minutes a user has to wait to retry an upload
rate-limit-message-minutes =
    { $retryLimit ->
        [one] Достигли сте ограничење за слање на овој страници. Сачекајте 1 минут пре слања следеће реченице. Хвала вам на стрпљењу!
        [few] Достигли сте ограничење за слање на овој страници. Сачекајте { $retryLimit } минута пре слања следеће реченице. Хвала вам на стрпљењу!
       *[other] Достигли сте ограничење за слање на овој страници. Сачекајте { $retryLimit } минута пре слања следеће реченице. Хвала вам на стрпљењу!
    }
# $retryLimit represents the amount of time in seconds a user has to wait to retry an upload
rate-limit-message-seconds =
    { $retryLimit ->
        [one] Достигли сте ограничење за слање на овој страници. Сачекајте 1 секунду пре слања следеће реченице. Хвала вам на стрпљењу!
        [few] Достигли сте ограничење за слање на овој страници. Сачекајте { $retryLimit } секунде пре слања следеће реченице. Хвала вам на стрпљењу!
       *[other] Достигли сте ограничење за слање на овој страници. Сачекајте { $retryLimit } секунди пре слања следеће реченице. Хвала вам на стрпљењу!
    }
# $uploadedSentences represents the number of sentences accepted from the small batch submission, $totalSentences represents the total number of sentences in the small batch submission
add-small-batch-success =
    { $totalSentences ->
        [one] Прикупљена је { $uploadedSentences } од 1 реченице
        [few] Прикупљене су { $uploadedSentences } од { $totalSentences } реченице
       *[other] Прикупљено је { $uploadedSentences } од { $totalSentences } реченица
    }
# $uploadedSentences represents the number of sentences accepted from the small batch submission, $totalSentences represents the total number of sentences in the small batch submission
small-batch-response-message =
    { $totalSentences ->
        [one] Прикупљена је { $uploadedSentences } од 1 реченице. Кликните <downloadLink>овде</downloadLink> да преузмете одбијене реченице.
        [few] Прикупљене су { $uploadedSentences } од { $totalSentences } реченице. Кликните <downloadLink>овде</downloadLink> да преузмете одбијене реченице.
       *[other] Прикупљено је { $uploadedSentences } од { $totalSentences } реченица. Кликните <downloadLink>овде</downloadLink> да преузмете одбијене реченице.
    }
