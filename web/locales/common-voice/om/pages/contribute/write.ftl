## SMALL BATCH SUBMISSION

# <icon></icon> will be replaced with an icon that represents writing a sentence
small-batch-instruction = Himoota public domain baay’ee dabaluu <icon></icon>
multiple-sentences-error = Himoota baay’ee galchuu hin dandeessu seensisa tokkoon
exceeds-small-batch-limit-error = Himoota 1000 ol galchuu hin dandeessu
# $retryLimit represents the amount of time in minutes a user has to wait to retry an upload
rate-limit-toast-message-minutes =
    { $retryLimit ->
        [one] Daangaa sadarkaa sakatta’amaa darbeera. Daqiiqaa 1 booda irra deebiin yaali
       *[other] Daangaa sadarkaa sakatta’amaa darbeera. Daqiiqaa { $retryLimit }  booda irra deebiin yaali
    }
# $retryLimit represents the amount of time in seconds a user has to wait to retry an upload
rate-limit-toast-message-seconds =
    { $retryLimit ->
        [one] Daangaa sadarkaa sakatta’amaa darbeera. Sekendii 1  booda irra deebiin yaali
       *[other] Daangaa sadarkaa sakatta’amaa darbeera. Sekendii { $retryLimit }  booda irra deebiin yaali
    }
# $retryLimit represents the amount of time in minutes a user has to wait to retry an upload
rate-limit-message-minutes =
    { $retryLimit ->
        [one] Daangaa galchaa fuula kanaa geesseerta. Daqiiqaa 1 booda hima biraa galchuu dandeessa. Obsa keef galatoomi!
       *[other] Daangaa galchaa fuula kanaa geesseerta. Daqiiqaa { $retryLimit } booda hima biraa galchuu dandeessa. Obsa keef galatoomi!
    }
# $retryLimit represents the amount of time in seconds a user has to wait to retry an upload
rate-limit-message-seconds =
    { $retryLimit ->
        [one] Daangaa galchaa fuula kanaa geesseerta. Sekendii 1 booda hima biraa galchuu dandeessa. Obsa keef galatoomi!
       *[other] Daangaa galchaa fuula kanaa geesseerta. Sekendii { $retryLimit } booda hima biraa galchuu dandeessa. Obsa keef galatoomi!
    }
# $uploadedSentences represents the number of sentences accepted from the small batch submission, $totalSentences represents the total number of sentences in the small batch submission
add-small-batch-success =
    { $totalSentences ->
        [one] { $uploadedSentences } keessaa himni 1 walitti qabame.
       *[other] { $uploadedSentences } keessaa himni { $totalSentences } walitti qabame.
    }
# $uploadedSentences represents the number of sentences accepted from the small batch submission, $totalSentences represents the total number of sentences in the small batch submission
small-batch-response-message =
    { $totalSentences ->
        [one] { $uploadedSentences } keessaa himni 1 walitti qabameera. Himoota dhorkaman buufachuuf <downloadLink>as</downloadLink> cuqaasi.
       *[other] { $uploadedSentences } keessaa himni { $totalSentences } walitti qabameera. Himoota dhorkaman buufachuuf <downloadLink>as</downloadLink> cuqaasi.
    }
small-batch-sentences-rule-1 = Qajeelfamoota hordofi "Himoota akkamii dabaluun danda’a?" jedhu keessaa
small-batch-sentences-rule-2 = Toora tokko irratti hima tokko galchi.
small-batch-sentences-rule-3 = Himoota tokkoon tokkoon sarara tokko tokkotti adda baasi; kana gochuuf ‘Enter’ yookaan ‘Return’ yeroo tokko cuqaasi
small-batch-sentences-rule-4 = Hanga himoota 1,000tti galchuun ni danda’ama.
small-batch-sentences-rule-5 = Himoonni hundi domain walfakkaataa qabaachuu qabu
small-batch-sentences-rule-6 = Himoonni hundi wabii walfakkaataa qabaachuu qabu
# menu item
add-sentences = Himoota ida'i

