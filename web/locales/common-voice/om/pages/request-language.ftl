## Request Language Pages

request-language-heading = Waa'ee afaan haaraa gaafadhu
request-language-explanation-1 = Afaan kee <languagesPageLink>fuula Afaanota Common Voice</languagesPageLink> irratti tarreeffamee jiraachuu isaa ilaali. Yoo hin jirre, foormii kana guuti, nuunis <strong>imeelii siif erguun akkamitti afaan kee qopheessuu akka dandeessu siif ibsina</strong>.
request-language-form-email =
    .label = Teessoo iimeelii kee
request-language-form-info =
    .label = Odeeffannoo waa'ee qooqa kee
request-language-form-info-explanation = Waa'ee afaanichaa odeeffannoo hamma dandeessan itti dabalaa. Kun kanneen armaan gadii of keessatti qabachuu danda’a:
request-language-form-info-explanation-list-1 = Maqaa qooqa keessanii
request-language-form-info-explanation-list-2 = <isoCodeLink>Koodiiwwan ISO</isoCodeLink> yoo beekaman
request-language-form-info-explanation-list-3 = Liinkii marsariitiiwwan afaanicha hubachuuf nu gargaaruu danda’an
request-language-google-recaptcha-required = yoo itti fufuu barbaadde reCAPTCHA barbaachisa
request-language-google-recaptcha-error = ReCAPTCHA irratti wanti ta'e dogoggora. Mee irra deebi'ii yaali.
# Success page
request-language-success-heading = Galatoomi! Gaaffii afaan haaraa ergiteetta
request-language-success-list-1 = Afaan keessan Common Voice irratti akka dabalamu tarkaanfiiwwan fudhataman kan ibsu Hogganaa Hawaasa keenyaa irraa email argachuu qabdu
request-language-success-list-2 = Hogganaan hawaasa keenyaa deeggarsa dabalataa siif kennuuf sin qunnama, akkasumas afaan kee irratti hawaasni hojjetaa jiru yoo jiraate si beeksisuuf.
request-language-success-list-3 =
    Guyyaa lama lama keessatti yoo nu hin dhageenye ta’e,
    <emailLink>{ $email }</emailLink> irratti qunnamaa
    nutis isinitti deebina!
request-language-error =
    Gaaffiin sun nu gaʼuu dhiisuu dandaʼa. Kallattiin email nuuf ergaa
    <emailLink>{ $email }</emailLink> irrattis isiniif deebisna!
request-for-scripted-speech-toggle = Gaaffii Haasaa Iskiriiptii
request-for-spontaneous-speech-toggle = Gaaffii Dubbii Ofumaan Dubbachuu
need-help-deciding-platform = Kam akka filattu murteessuuf gargaarsa barbaadduu?
