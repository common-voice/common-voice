## SMALL BATCH SUBMISSION

# <icon></icon> will be replaced with an icon that represents writing a sentence
small-batch-instruction = <icon></icon> Ajoute plizyè fraz adan domèn piblik
multiple-sentences-error = Ou pa ka ajoute plizyè fraz pou an sèl soumèt.
exceeds-small-batch-limit-error = Pa ka soumèt plis ki 1000 fraz
# $retryLimit represents the amount of time in minutes a user has to wait to retry an upload
rate-limit-toast-message-minutes =
    { $retryLimit ->
        [one] Limit vitès la depase. Eseye ankò dan 1 minit a lòt
       *[other] Limit vitès la depase. Eseye ankò nan { $retryLimit } minit
    }
# $retryLimit represents the amount of time in seconds a user has to wait to retry an upload
rate-limit-toast-message-seconds =
    { $retryLimit ->
        [one] Limit vitès la depase. Eseye ankò an 1 segonn
       *[other] Limit vitès la depase. Eseye ankò  { $retryLimit } segonn
    }
# $retryLimit represents the amount of time in minutes a user has to wait to retry an upload
rate-limit-message-minutes =
    { $retryLimit ->
        [one] Ou rive adan an limit soumèt pou paj ta la. Souplé atann 1 minit anvan ou soumèt an lòt fraz. Mèsi pou pasyans ou!
       *[other] Ou rive adan limit soumèt pou paj ta la. Souplé atann { $retryLimit } minit anvan ou soumèt an lòt fraz. Mèsi pou pasyans ou!
    }
# $retryLimit represents the amount of time in seconds a user has to wait to retry an upload
rate-limit-message-seconds =
    { $retryLimit ->
        [one] Ou rive adan limit soumèt pou paj ta la. Souplé atann 1 segonn anvan ou soumèt an lòt fraz. Mèsi pou pasyans ou!
       *[other] Ou rive adan limit soumèt pou paj ta la. Souplé atann { $retryLimit } segonn anvan ou soumèt an lòt fraz. Mèsi pou pasyans ou!
    }
# $uploadedSentences represents the number of sentences accepted from the small batch submission, $totalSentences represents the total number of sentences in the small batch submission
add-small-batch-success =
    { $totalSentences ->
        [one] yon{ $uploadedSentences } an 1 fraz kolekte
       *[other] { $uploadedSentences } an { $totalSentences } fraz kolekte
    }
# $uploadedSentences represents the number of sentences accepted from the small batch submission, $totalSentences represents the total number of sentences in the small batch submission
small-batch-response-message =
    { $totalSentences ->
        [one] { $uploadedSentences }  1 fraz kolekte. Klike <downloadLink>isi </downloadLink> pou telechaje fraz yo rejite .
       *[other] { $uploadedSentences } nan { $totalSentences } fraz kolekte. Klike <downloadLink>isi</downloadLink> pou telechaje fraz yo rejite .
    }
