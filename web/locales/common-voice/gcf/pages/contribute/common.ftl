shortcut-rerecord-toggle = [1-5]
shortcut-rerecord-toggle-label = Anrejistre klip la ankò
shortcut-discard-ongoing-recording = ESC
shortcut-discard-ongoing-recording-label = Anile anrejistreman ki ka kontinye.
