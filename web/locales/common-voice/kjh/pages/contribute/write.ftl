# $retryLimit represents the amount of time in minutes a user has to wait to retry an upload
rate-limit-toast-message-minutes =
    { $retryLimit ->
        [one] Табырахтың лимиді ас парыбысхан. 1 минута пазынаң хатап сынап кӧріңер
       *[other] Табырахтың лимиді ас парыбысхан. { $retryLimit } минут пазынаң хатап сынап кӧріңер
    }
# $retryLimit represents the amount of time in seconds a user has to wait to retry an upload
rate-limit-toast-message-seconds =
    { $retryLimit ->
        [one] Табырахтың лимиді ас парыбысхан. 1 минута пазынаң хатап сынап кӧріңер
       *[other] Табырахтың лимиді ас парыбысхан. { $retryLimit } минут пазынаң хатап сынап кӧріңер
    }
# $retryLimit represents the amount of time in minutes a user has to wait to retry an upload
rate-limit-message-minutes =
    { $retryLimit ->
        [one] Сірер пу страницаның ысчаң лимидына чит парғазар. Наа чоохтағ ызар алнында 1 минута сахтап алыңардах. Тыстаныс ӱчӱн алғыс!
       *[other] Сірер пу страницаның ысчаң лимидына чит парғазар. Наа чоохтағ ызар алнында { $retryLimit } минут сахтап алыңардах. Тыстаныс ӱчӱн алғыс!
    }
# $retryLimit represents the amount of time in seconds a user has to wait to retry an upload
rate-limit-message-seconds =
    { $retryLimit ->
        [one] Сірер пу страницаның кӧзітчең лимидына чит парғазар. Наа чоохтағ ызар алнында 1 минута сахтап алыңардах. Тыстаныс ӱчӱн алғыс!
       *[other] Сірер пу страницаның кӧзітчең лимидына чит парғазар. Наа чоохтағ ызар алнында { $retryLimit } минут сахтап алыңардах. Тыстаныс ӱчӱн алғыс!
    }
# $uploadedSentences represents the number of sentences accepted from the small batch submission, $totalSentences represents the total number of sentences in the small batch submission
add-small-batch-success =
    { $totalSentences ->
        [one] 1 чоохтағның { $uploadedSentences }-зі чыыл парған
       *[other] { $totalSentences } чоохтағның { $uploadedSentences }-зі чыыл парған
    }
# $uploadedSentences represents the number of sentences accepted from the small batch submission, $totalSentences represents the total number of sentences in the small batch submission
small-batch-response-message =
    { $totalSentences ->
        [one] 1 чоохтағның { $uploadedSentences }-зі чыыл парған. Алылған чоохтағларны сығарып алар ӱчӱн <downloadLink>мында </downloadLink> пазыбызыңар.
       *[other] { $totalSentences } чоохтағның { $uploadedSentences }-зі чыыл парған. Алылған чоохтағларны сығарып алар ӱчӱн <downloadLink>мында </downloadLink> пазыбызыңар.
    }
