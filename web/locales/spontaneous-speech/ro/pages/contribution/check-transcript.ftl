## Check Transcriptions page

# actionType will be Click (for desktop devices) or Tap (for mobile devices)
transcription-page-instruction = { $actionType } <playIcon></playIcon> Ascultă clipul audio și verifică transcrierea. Se potrivește? Dacă nu, editează pentru corelare perfectă.
# Header of the textbox that contains a transcription of an audio
check-editbox-header = Verifică
# Message which appears when there are no more resources on this page
no-transcriptions-continue-skipped-message = Nu există transcrieri de verificat pentru această limbă. Dacă ai sărit vreuna, poți continua cu conținutul sărit sau poți merge să transcrii audio și să încerci din nou mai târziu.
vote-transcript-success = Transcriere votată cu succes
vote-transcript-error = A apărut o eroare la votarea transcrierii
transcript-edited-success = Transcriere editată cu succes
transcript-edited-error = A apărut o eroare la editarea transcrierii
error-fetching-transcriptions = Ceva nu a funcționat la preluarea transcrierilor. Te rugăm să încerci din nou mai târziu.
transcript-skipped-success = Transcriere omisă cu succes
transcript-skipped-error = A apărut o eroare la omiterea transcrierii
# For the button on the Check Transcriptions page to assert that a transcription is correct
correct = Corect
# For the button on the Check Transcriptions page to indicate that a user has finished editing a transcription
done = Terminat
# For the button on the Check Transcriptions page to edit a transcription
edit = Editează
