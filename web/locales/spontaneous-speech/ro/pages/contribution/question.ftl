## Question Page

question-page-instruction = Adaugă o întrebare <icon></icon> în { $currentLocale } la care să răspundă alții
add-question-textarea-placeholder = De ex.: „La ce ți-ai dori să poți folosi tehnologia?”
add-questions-terms-checkbox = * Confirm că întrebarea este de <publicDomainLink>domeniul public</publicDomainLink> și am permisiunea să o încarc aici.
question-dataset-language = Set de date: { $datasetLanguage }
add-question-success-toast-message =
    { $totalQuestions ->
        [one] { $uploadedQuestions } din 1 întrebare colectată
        [few] { $uploadedQuestions } din { $totalQuestions } întrebări colectate
       *[other] { $uploadedQuestions } din { $totalQuestions } de întrebări colectate
    }
add-question-error-message = Încărcarea a eșuat. Te rugăm să mai încerci o dată.
add-question-too-many-questions-error = Ai depășit 25 de întrebări. Redu numărul de întrebări și încearcă din nou.
partial-questions-upload-message =
    { $totalQuestions ->
        [one] { $uploadedQuestions } din 1 întrebare colectată. Vezi paginile <guidelinesLink>Ghidului</guidelinesLink> ca să afli mai multe despre adăugarea de întrebări
        [few] { $uploadedQuestions } din 1 întrebare colectate. Vezi paginile <guidelinesLink>Ghidului</guidelinesLink> ca să afli mai multe despre adăugarea de întrebări
       *[other] { $uploadedQuestions } din 1 întrebare colectate. Vezi paginile <guidelinesLink>Ghidului</guidelinesLink> ca să afli mai multe despre adăugarea de întrebări
    }
# Guidelines
add-question-guidelines-title = Ce întrebări pot adăuga?
do-section-title = așa da
do-section-guideline-1 = Folosește corect ortografia și gramatica
do-section-guideline-2 = Propune întrebări simple, ușor de înțeles de către oricine, indiferent de cultura din care vine sau de contextul în care trăiește
do-section-guideline-3 = Asigură-te că se pot da răspunsuri de numai câteva propoziții
do-not-section-title = așa nu
do-not-section-guideline-1 = Cere informații de identificare personală (cum ar fi nume sau informații financiare)
do-not-section-guideline-2 = Exprimă sau incită la sentimente de prejudecată sau jignitoare
do-not-section-guideline-3 = Pune întrebări sensibile
# Code switching Guidelines
cs-do-section-guideline-1 = Folosește întrebări sau context bilingv(e)
cs-do-section-guideline-2 = Explorează scenarii, situații sau reconstituiri informale
cs-do-not-section-guideline-1 = Solicită informații de identificare personală (cum ar fi nume sau informații financiare) sau incită la sentimente jignitoare
cs-do-not-section-guideline-2 = Cere alternanță lingvistică sau cere traducere
cs-do-not-section-guideline-3 = Folosește un limbaj prea formal
