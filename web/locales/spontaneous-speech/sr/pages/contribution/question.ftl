## Question Page

question-page-instruction = Додајте питање <icon></icon> на језику { $currentLocale } на које ће људи одговарати
add-question-textarea-placeholder = нпр. „Шта бисте волели да можете да радите помоћу технологије?”
add-questions-terms-checkbox = * Потврђујем да је ово питање у <publicDomainLink>јавном власништву</publicDomainLink> и да имам дозволу да га отпремим.
question-dataset-language = Скуп података: { $datasetLanguage }
add-question-success-toast-message =
    { $totalQuestions ->
        [one] Прикупљено је { $uploadedQuestions } од 1 питања
        [few] Прикупљена су { $uploadedQuestions } од { $totalQuestions } питања
       *[other] Прикупљено је { $uploadedQuestions } од { $totalQuestions } питања
    }
add-question-error-message = Отпремање није успело, покушајте поново.
add-question-too-many-questions-error = Премашено је 25 питања. Смањите број питања и покушајте поново.
partial-questions-upload-message =
    { $totalQuestions ->
        [one] Прикупљено је { $uploadedQuestions } од 1 питања. Погледајте наше странице са <guidelinesLink>смерницама</guidelinesLink> да бисте сазнали више о томе како да додате питања
        [few] Прикупљена су { $uploadedQuestions } од { $totalQuestions } питања. Погледајте наше странице са <guidelinesLink>смерницама</guidelinesLink> да бисте сазнали више о томе како да додате питања
       *[other] Прикупљено је { $uploadedQuestions } од { $totalQuestions } питања. Погледајте наше странице са <guidelinesLink>смерницама</guidelinesLink> да бисте сазнали више о томе како да додате питања
    }
# Guidelines
add-question-guidelines-title = Која питања могу да додам?
do-section-title = треба
do-section-guideline-1 = Користите исправан правопис и граматику
do-section-guideline-2 = Бирајте једноставна питања која свако може лако да разуме, без обзира на културу или контекст
do-section-guideline-3 = Уверите се да се на њих може одговорити у само пар реченица
do-not-section-title = не треба
do-not-section-guideline-1 = Тражити податке који откривају лични идентитет (попут имена или финансијских података)
do-not-section-guideline-2 = Изражавати или подстицати предрасуде или увредљиве ставове
do-not-section-guideline-3 = Постављати осетљива питања
# Code switching Guidelines
cs-do-section-guideline-1 = Користити двојезична питања или контекст
cs-do-section-guideline-2 = Истражите неформалне сценарије, ситуације или реконструкције
cs-do-not-section-guideline-1 = Тражите личне податке за идентификацију (попут имена или финансијских информација) или увредљиве ставове
cs-do-not-section-guideline-2 = Тражите мешање језика или захтевајте превод
cs-do-not-section-guideline-3 = Користите превише формалан језик
