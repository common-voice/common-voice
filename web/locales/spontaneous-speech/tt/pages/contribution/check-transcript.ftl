## Check Transcriptions page

# actionType will be Click (for desktop devices) or Tap (for mobile devices)
transcription-page-instruction = { $actionType } <playIcon></playIcon> Аудиоклипны тыңлап карагыз һәм транскрипцияне тикшерегез. Ул туры киләме? Туры килмәсә, аны төзәтегез. Аудиоклип һәм транскрипция бер-берсенә туры килергә тиеш.
# Header of the textbox that contains a transcription of an audio
check-editbox-header = Тикшерү
# Message which appears when there are no more resources on this page
no-transcriptions-continue-skipped-message = Әлегә бу тел өчен транскрипцияләр юк. Берәрсен калдырып үтеп киткән булсагыз, эшне шуннан дәвам итәргә яки әлегә аудионы транскриблауга күчеп, башка вакытта яңадан тикшерүгә кайтырга була.
vote-transcript-success = Тавыш транскрипциясе өчен тавыш уңышлы бирелде
vote-transcript-error = Транскрипция өчен тавыш бирелгәндә хата чыкты
transcript-edited-success = Транскрипция уңышлы үзгәртелде
transcript-edited-error = Транскрипцияне үзгәрткәндә хата чыкты
error-fetching-transcriptions = Транскрипцияне алганда нәрсәдер дөрес бармады. Бераз гына көтегез һәм аннары яңадан кабатлагыз.
transcript-skipped-success = Транскрипция уңышлы үтеп кителде
transcript-skipped-error = Транскрипцияне үтеп киткәндә хата булды
# For the button on the Check Transcriptions page to assert that a transcription is correct
correct = Дөрес
# For the button on the Check Transcriptions page to indicate that a user has finished editing a transcription
done = Әзер
# For the button on the Check Transcriptions page to edit a transcription
edit = Үзгәртү
