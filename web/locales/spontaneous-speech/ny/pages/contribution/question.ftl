## Question Page

question-page-instruction = Onjezalani funso <icon></icon> mu { $currentLocale } kuti anthu ayankhe
add-question-textarea-placeholder = mwachitsanzo, “Mukufuna kuti mugwiritse ntchito ukadaulo wa tekinologe pa chiyani?
add-questions-terms-checkbox = * Ndikutsimikiza kuti funso ili ndi <publicDomainLink>public domain</publicDomainLink> ndipo ndili ndi chilolezo kuyika
question-dataset-language = Seti ya deta: { $datasetLanguage }
add-question-success-toast-message =
    { $totalQuestions ->
        [one] Mafunso { $uploadedQuestions } mwa mafunso { $totalQuestions } omwe asonkhanitsidwa
       *[other] { "" }
    }
add-question-error-message = Kukweza kwalephera, chonde yesaninso.
add-question-too-many-questions-error = mwadutsitsa mafunso 25. Chepetsani chiwerengero cha mafunso ndipo muyesenso.
partial-questions-upload-message =
    { $totalQuestions ->
        [one] Mafunso { $uploadedQuestions } mwa mafunso { $totalQuestions } omwe asonkhanitsidwa. Onani masamba athu a
       *[other] <guidelinesLink>Malangizo</guidelinesLink> kuti mudziwe zambiri za momwe mungawonjezere mafunso
    }
# Guidelines
add-question-guidelines-title = Ndi mafunso ati omwe ndingawonjezere?
do-section-title = chitani kapena pangani
do-section-guideline-1 = Gwiritsani ntchito kalembedwe koyenera ndi galamala
do-section-guideline-2 = Sankhani mafunso osavuta omwe aliyense angamvetse, mosasamala kanthu pa zachikhalidwe kapena momwe zinthu zilili
do-section-guideline-3 = Onetsetsani kuti akhonza kuyankhidwa m'ziganizo zingapo
do-not-section-title = osa
do-not-section-guideline-1 = Funsani zambiri zomwe zingazindikiritse munthu payekha (monga mayina kapena zambiri zachuma)
do-not-section-guideline-2 = Fotokozani kapena pemphani malingaliro olakwika kapena okhumudwitsa
do-not-section-guideline-3 = Funsa mafunso ovuta kapena achinsinsi
# Code switching Guidelines
cs-do-section-guideline-1 = Gwiritsani ntchito zilankhulo ziwiri pofunsa mafunso kapena fotokozani nkhaniyo bwinobwino
cs-do-section-guideline-2 = Fufuzani nkhani, zochitika, kapena masewero a momwe anthu amakhalila
cs-do-not-section-guideline-1 = Pemphani zambiri zodzizindikiritsa nokha (monga mayina kapena zambiri zachuma) kapena malingaliro okhumudwitsa
cs-do-not-section-guideline-2 = Pemphani kumasulira kapena kusakaniza zilankhulo
cs-do-not-section-guideline-3 = Gwiritsani ntchito mawu ovomerezeka kwambiri
