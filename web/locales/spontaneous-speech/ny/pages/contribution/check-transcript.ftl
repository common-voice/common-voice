## Check Transcriptions page

# actionType will be Click (for desktop devices) or Tap (for mobile devices)
transcription-page-instruction = { $actionType } <playIcon></playIcon> Mvetserani kanema wamawu, ndikuwona momwe mawuwo alembedwera. Kodi akugwirizana? Ngati sichoncho, sinthani kuti agwirizane bwino.
# Header of the textbox that contains a transcription of an audio
check-editbox-header = onaniso
# Message which appears when there are no more resources on this page
no-transcriptions-continue-skipped-message = Pakadali pano palibe zolembedwa zoti muwone ngati zili m'chinenerochi. Ngati mwadumpha chilichonse, mutha kupitiriza ndi zomwe mwadumpha kapena kupita kukalemba mawu ndikuyesanso pambuyo pake.
vote-transcript-success = zoolembedwacho chavoteredwa bwino
vote-transcript-error = Panali cholakwika povota chikalatacho
transcript-edited-success = Cholembedwacho chasinthidwa bwino
transcript-edited-error = Panali cholakwika positha zolembedwazo
error-fetching-transcriptions = Chinachake chalakwika potenga zolemba. Yesaninso pambuyo pake.
transcript-skipped-success = Cholembedwacho chadumphidwa bwinobwino
transcript-skipped-error = Cholakwika zachitika pamene mumadumpha mawu olembedwa.
# For the button on the Check Transcriptions page to assert that a transcription is correct
correct = Zolondola
# For the button on the Check Transcriptions page to indicate that a user has finished editing a transcription
done = Zatha
# For the button on the Check Transcriptions page to edit a transcription
edit = Sinthani
