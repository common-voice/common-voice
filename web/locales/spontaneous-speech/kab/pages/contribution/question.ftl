## Question Page

question-page-instruction = Rnu asteqsi <icon></icon> deg { $currentLocale } i wakken ad izmiren yimdanen ad d-rren
add-question-textarea-placeholder = am., “Acu i tebɣiḍ ad t-tgeḍ d tetiknulujit?”
question-dataset-language = Tagrumma n yisefka: { $datasetLanguage }
add-question-success-toast-message =
    { $totalQuestions ->
        [one] { $uploadedQuestions } n 1 usteqsi i d-yettwaleqḍen
       *[other] { $uploadedQuestions } n { $totalQuestions } yisteqsiyen i d-yettwalqaḍen
    }
add-question-error-message = Asali yecceḍ, ttxil εreḍ ticki.
add-question-too-many-questions-error = Tɛeddaḍ 25 n tuttriwin. Senqes amḍan n yisteqsiyen, sakin ɛreḍ.
# Guidelines
add-question-guidelines-title = Acu n usteqsi i zemreɣ ad rnuɣ?
do-section-title = eg
do-section-guideline-3 = Tḥeqqeq belli zemren ad d-rren s kra kan n tefyar
do-not-section-title = ur tegg ara
do-not-section-guideline-3 = Mudd isteqsiyen imḥulfa
cs-do-not-section-guideline-2 = Steqsi ɣef ubeddel n tutlayt neɣ suter n tasuqilt
