## Question Page

question-page-instruction = Namoonni akka deebii kennan gaaffii <icon></icon> { $currentLocale } keessatti dabali
add-question-textarea-placeholder = fkn, “Teeknooloojii maaliif fayyadamuu barbaadda?”
add-questions-terms-checkbox = * Gaaffiin kun <publicDomainLink>public domain</publicDomainLink> ta'uu isaa fi olfe'amuuf hayyama akka qabu nan mirkaneessa.
question-dataset-language = Daataaseetii: { $datasetLanguage }
add-question-success-toast-message =
    { $totalQuestions ->
        [one] { $uploadedQuestions } keessaa gaaffii 1tu walitti qabame
       *[other] { $totalQuestions } keessaa gaaffilee { $uploadedQuestions }tu walitti qabame
    }
add-question-error-message = Fe'uun hin milkoofne, maaloo irra deebiin yaali.
add-question-too-many-questions-error = Gaaffii 25 ol ta'e. Lakkoofsa gaaffii hir'isuun irra deebi'aa yaalaa.
partial-questions-upload-message =
    { $totalQuestions ->
        [one] { $uploadedQuestions } keessaa gaaffii 1tu walitti qabame. Akkaataa gaaffiin itti dabalu caalaatti baruuf fuula keenya <guidelinesLink>Qajeelfama</guidelinesLink> ilaali
       *[other] { $uploadedQuestions } keessaa gaaffileen { $totalQuestions }tu walitti qabame. Akkaataa gaaffiin itti dabalu caalaatti baruuf fuula keenya <guidelinesLink>Qajeelfama</guidelinesLink> ilaali
    }
# Guidelines
add-question-guidelines-title = Gaaffii akkamii dabaluu danda'a?
do-section-title = hojjedhu
do-section-guideline-1 = Qubeessuu fi caasluga sirrii fayyadamuu
do-section-guideline-2 = Gaaffilee salphaa namni kamiyyuu salphaatti hubachuu danda’u, aadaa fi haala dubbii osoo hin ilaalin filadhu
do-section-guideline-3 = Hima lama lama qofaan deebii argachuu akka danda’an mirkaneessi
do-not-section-title = akkas hin godhinaa
do-not-section-guideline-1 = Odeeffannoo dhuunfaa adda baasuu (akka maqaa ykn odeeffannoo maallaqaa) gaafachuu .
do-not-section-guideline-2 = Miira loogii ykn nama aarsu ibsuu ykn gaafachuu
do-not-section-guideline-3 = Gaaffiiwwan miira namaa kakaasan gaafadhu
# Code switching Guidelines
cs-do-section-guideline-1 = Gaaffii afaan lamaa ykn haala dubbii fayyadami
cs-do-section-guideline-2 = Haala al-seerummaa, haalyeroowwan ykn kan irra deebi’anii mul’atan qoradhu
cs-do-not-section-guideline-1 = Odeeffannoo dhuunfaa adda baasuu (akka maqaa ykn odeeffannoo maallaqaa) ykn miira nama aarsu gaafachuu
cs-do-not-section-guideline-2 = Koodii jijjiiruu gaafadhu ykn hiikkaa gaafadhu
cs-do-not-section-guideline-3 = Afaan sirnaa garmalee fayyadamuu
